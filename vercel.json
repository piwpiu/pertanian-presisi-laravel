{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.7.4" }
    },
    "routes": [
        { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/public/(.*)", "dest": "/public/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "public": true,
    "buildCommand": "vite build",
    "outputDirectory": "public"
}
